{
  "AllowedHosts": "*",
  //"AppConfig": {
  //  "Endpoint": ""
  //},
  //"APPLICATIONINSIGHTS_CONNECTION_STRING": "",
  //"ConnectionStrings:AzureAppConfiguration": "",
  "CustomHeader": "default",
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "FeatureManagement": {
    "MockService1PermanentExceptionToggle": false,
    "MockService1TransientExceptionToggle": false,
    "MockService1CpuThrottleToggle": false
  },
  "MockService1CpuThrottleIterations": 0,
  "Serilog": {
    "Enrich": [
      "FromLogContext",
      "WithMachineName"
    ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning"
      }
    },
    "Properties": {
      "Application": "Service1 Application"
    },
    "Using": [
      "Serilog.Sinks.ApplicationInsights"
    ],
    "WriteTo": [
      {
        "Name": "ApplicationInsights",
        "Args": {
          "connectionString": "",
          "telemetryConverter": "Serilog.Sinks.ApplicationInsights.TelemetryConverters.TraceTelemetryConverter, Serilog.Sinks.ApplicationInsights"
        }
      },
      {
        "Name": "Console",
        "Args": {
          "outputTemplate": "[{Timestamp:yyyy-MM-dd @ HH:mm:ss.fff}] [{Level:u3}] [{SourceContext}] {Message}{NewLine}"
          // this is an example with more robust data included in a differently formatted log entry
          //"outputTemplate": "[{Timestamp:yyyy-MM-dd @ HH:mm:ss.fff}] [{Level:u3}] [{MachineName}] [{SourceContext}] {Message}{NewLine}{Exception}"
        }
      }
      //{
      //  "Name": "File",
      //  "Args": {
      //    "path": "D:\\home\\LogFiles\\webapplication1\\serilog\\log.json",
      //    "formatter": "Serilog.Formatting.Json.JsonFormatter, Serilog"
      //  }
      //}
    ]
  }
}
