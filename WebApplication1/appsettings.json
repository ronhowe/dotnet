{
  "AllowedHosts": "*",
  // this one is used by a managed identity call
  // see secrets.json
  "AppConfig": {
    "Endpoint": ""
  },
  // see secrets.json
  "APPLICATIONINSIGHTS_CONNECTION_STRING": "",
  // this one is used by a connection string call
  // see secrets.json
  "ConnectionStrings:AzureAppConfiguration": "",
  "CustomHeader": "default",
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "MockService1PermanentExceptionToggle": false,
  "MockService1TransientExceptionToggle": false,
  "Serilog": {
    "Enrich": [
      "FromLogContext",
      "WithMachineName"
    ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning"
      }
    },
    "Properties": {
      "Application": "Service1 Application"
    },
    "Using": [
      "Serilog.Sinks.ApplicationInsights"
    ],
    "WriteTo": [
      {
        "Name": "ApplicationInsights",
        "Args": {
          "connectionString": "",
          "telemetryConverter": "Serilog.Sinks.ApplicationInsights.TelemetryConverters.TraceTelemetryConverter, Serilog.Sinks.ApplicationInsights"
        }
      },
      {
        "Name": "Console",
        "Args": {
          "outputTemplate": "[{SourceContext}] {Message}{NewLine}"
          //"outputTemplate": "[{Timestamp:HH:mm:ss.fff zzz}] [{Level:u3}] [{MachineName}] [{SourceContext}] {Message}{NewLine}{Exception}"
        }
      }
      //{
      //  "Name": "File",
      //  "Args": {
      //    "path": "D:\\home\\LogFiles\\webapplication1\\serilog\\log.json",
      //    "formatter": "Serilog.Formatting.Json.JsonFormatter, Serilog"
      //  }
      //}
    ]
  }
}
