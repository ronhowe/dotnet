{
  //"https": null, //learn.microsoft.com/en-us/aspnet/core/fundamentals/servers/kestrel?view=aspnetcore-8.0#host-filtering
  // TODO - Enforce narrow host list?
  "AllowedHosts": "*",
  "AppConfig": {
    "Endpoint": "https://appcs-ronhowe-000.azconfig.io"
  },
  "CustomHeader": "default",
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "MockServiceExceptionToggle": false,
  "Serilog": {
    "Enrich": [
      "FromLogContext",
      "WithMachineName"
    ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning"
      }
    },
    "WriteTo": [
      // TODO - Optionally log to file.
      //{
      //  "Name": "File",
      //  "Args": {
      //    "path": "D:\\Logs\\structuredLog.json",
      //    "formatter": "Serilog.Formatting.Json.JsonFormatter, Serilog"
      //  }
      //},
      {
        "Name": "Console",
        "Args": {
          // TODO - Optionally sync with Program.cs for consistency in log message styling.
          "outputTemplate": "[{Level}] at [{Timestamp:HH:mm:ss.fff zzz}] on [{MachineName}] in [{SourceContext}] @ {Message}{NewLine}{Exception}"
        }
      }
    ]
  }
}
